# FreshBooks OAuth2 credentials
# Get these from https://my.freshbooks.com/#/developer
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
FRESHBOOKS_REDIRECT_URI=https://localhost/callback

# Tokens obtained after completing the OAuth flow
FRESHBOOKS_ACCESS_TOKEN=
FRESHBOOKS_REFRESH_TOKEN=

# Your FreshBooks account ID (for accounting endpoints: invoices, clients, expenses, payments)
FRESHBOOKS_ACCOUNT_ID=

# Your FreshBooks business ID (for project endpoints: time entries, projects, services)
FRESHBOOKS_BUSINESS_ID=
