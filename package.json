{
  "name": "freshbooks-mcp",
  "version": "2.0.4",
  "description": "MCP server exposing 75 FreshBooks accounting tools for AI assistants",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kanjidoc/FreshBooks-MCP.git"
  },
  "homepage": "https://github.com/kanjidoc/FreshBooks-MCP#readme",
  "bugs": {
    "url": "https://github.com/kanjidoc/FreshBooks-MCP/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "setup": "ts-node scripts/setup.ts",
    "check-tokens": "ts-node scripts/refresh-tokens.ts --check-only",
    "refresh-tokens": "ts-node scripts/refresh-tokens.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run"
  },
  "keywords": [
    "freshbooks",
    "mcp",
    "ai",
    "tools"
  ],
  "author": "kanjidoc",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97",
    "@freshbooks/api": "^4.1.0",
    "big.js": "^7.0.1",
    "dotenv": "^17.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.5.2",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
